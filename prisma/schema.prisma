datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Cliente {
  id        Int     @id @default(autoincrement())
  nome      String
  cpf       String? @unique
  empresaId Int     @map("empresa_id") // Mapeia o nome da coluna no Postgres (snake_case)

  @@map("clientes") // Mapeia o nome da tabela no Postgres (plural)
}